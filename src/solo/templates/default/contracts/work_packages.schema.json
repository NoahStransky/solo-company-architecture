{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Solo Work Packages",
  "type": "object",
  "required": ["work_packages"],
  "properties": {
    "work_packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "agent_role": {"type": "string", "default": "dev"},
          "files_scope": {"type": "array", "items": {"type": "string"}},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "agent_instance": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
